# VITE_SUPABASE_URL: Project URL from Supabase Dashboard > Project Settings > API.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# VITE_SUPABASE_ANON_KEY: Public anon key from Supabase Dashboard > Project Settings > API.
# Safe to expose client-side — access is enforced by Row Level Security policies.
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
